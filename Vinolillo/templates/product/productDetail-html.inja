<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ store_name }} — {{ producto_actual.nombre }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="/assets/vinolillo.css"/>
</head>
<body>

<header class="vino-nav" id="mainNav">
  <div class="d-flex align-items-center gap-5 flex-grow-1">
    <a href="index.html" class="brand">{{ store_name | upper }}</a>
    <nav class="vino-nav-links">
      <a href="../VinolilloCatalogPage.html" class="active">VINOS</a>
      <a href="../VinolilloCatalogPage.html">DESTILADOS</a>
      <a href="../VinolilloCatalogPage.html">CERVEZAS</a>
      <a href="../VinolilloCatalogPage.html">LICORES</a>
      <a href="../VinolilloCatalogPage.html">PROMOCIONES</a>
    </nav>
  </div>
  <div class="d-flex align-items-center gap-3 ms-auto">
    <button class="btn btn-link text-dark p-1" aria-label="Buscar"><span class="material-symbols-outlined">search</span></button>
    <button class="btn btn-link text-dark p-1" aria-label="Mi cuenta"><span class="material-symbols-outlined">settings</span></button>
    <a href="CartPage.html" class="text-dark p-1" style="position:relative; text-decoration:none;">
      <span class="material-symbols-outlined">shopping_cart</span>
      <span class="vino-cart-badge">2</span>
    </a>
  </div>
</header>

<main class="page-content" style="padding-bottom:80px;">
  <div class="container-fluid" style="max-width:1280px; margin:0 auto; padding:32px var(--margin-desk) 0;">

    <nav class="d-flex align-items-center py-3 text-uppercase fw-semibold mb-5" style="font-size:11px; letter-spacing:0.1em; color:var(--vino-muted); gap:4px;">
      <a href="index.html" class="text-decoration-none" style="color:var(--vino-secondary);">Inicio</a>
      <span class="material-symbols-outlined" style="font-size:14px; color:var(--vino-border);">chevron_right</span>
      <a href="VinolilloCatalogPage.html" class="text-decoration-none" style="color:var(--vino-secondary);">{{ producto_actual.categoria }}</a>
      <span class="material-symbols-outlined" style="font-size:14px; color:var(--vino-border);">chevron_right</span>
      <a href="VinolilloCatalogPage.html" class="text-decoration-none" style="color:var(--vino-secondary);">{{ producto_actual.subcategoria }}</a>
      <span class="material-symbols-outlined" style="font-size:14px; color:var(--vino-border);">chevron_right</span>
      <span style="color:var(--vino-on-surface);">{{ producto_actual.nombre }}</span>
    </nav>

    <div class="row g-5 mb-5">
      <div class="col-12 col-md-5">
        <div class="product-detail-img position-relative">
          {% if producto_actual.badge %}
          <span class="vino-card-badge bg-burgundy position-absolute" style="top:16px; left:16px;">{{ producto_actual.badge }}</span>
          {% endif %}
          <img src="{{ producto_actual.imagen }}" alt="{{ producto_actual.nombre }}"/>
        </div>
      </div>

      <div class="col-12 col-md-7">
        <a href="#" class="text-uppercase fw-semibold text-decoration-none d-block mb-2 text-burgundy-light" style="font-size:11px; letter-spacing:0.13em;">{{ producto_actual.marca }}</a>
        <h1 class="display-5 mb-3 fw-bold text-dark">{{ producto_actual.nombre }}</h1>
        <div class="d-flex align-items-center gap-3 mb-5">
          <span class="fs-2 fw-bold text-burgundy-light">₡{{ producto_actual.precio_crc }}</span>
          <span class="text-uppercase fw-semibold text-muted" style="font-size:11px; letter-spacing:0.13em;">{{ producto_actual.contenido_ml }}ml</span>
        </div>

        <div class="mb-5">
          <div class="d-flex justify-content-between align-items-baseline py-2 border-bottom border-top border-secondary-subtle">
            <span class="text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.15em;">Cosecha</span>
            <span class="fw-medium text-dark" style="font-size:14px;">{{ producto_actual.anio_cosecha }}</span>
          </div>
          <div class="d-flex justify-content-between align-items-baseline py-2 border-bottom border-secondary-subtle">
            <span class="text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.15em;">Origen</span>
            <span class="fw-medium text-dark" style="font-size:14px;">{{ producto_actual.region }}, {{ producto_actual.pais }}</span>
          </div>
          <div class="d-flex justify-content-between align-items-baseline py-2 border-bottom border-secondary-subtle">
            <span class="text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.15em;">Uva</span>
            <span class="fw-medium text-dark" style="font-size:14px;">{{ producto_actual.cepa }}</span>
          </div>
          <div class="d-flex justify-content-between align-items-baseline py-2 border-bottom border-secondary-subtle">
            <span class="text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.15em;">Alcohol</span>
            <span class="fw-medium text-dark" style="font-size:14px;">{{ producto_actual.alcohol }}%</span>
          </div>
          {% if producto_actual.descuento > 0 %}
          <div class="d-flex justify-content-between align-items-baseline py-2 border-bottom border-secondary-subtle">
            <span class="text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.15em;">Descuento</span>
            <span class="fw-medium text-dark" style="font-size:14px;">{{ producto_actual.descuento }}% OFF</span>
          </div>
          {% endif %}
        </div>

        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="qty-stepper d-inline-flex">
            <button class="px-2" aria-label="Disminuir">−</button>
            <span class="d-flex align-items-center justify-content-center border-start border-end fw-semibold" style="min-width:40px; font-size:14px;">1</span>
            <button class="px-2" aria-label="Aumentar">+</button>
          </div>
          <button class="btn-vino btn-vino-primary flex-grow-1 py-3" data-add-cart>
            <span class="material-symbols-outlined fs-5">shopping_basket</span>
            AGREGAR AL CARRITO
          </button>
        </div>

        <div data-tabs>
          <div class="d-flex border-bottom mb-3" style="gap:28px;">
            <button class="bg-transparent border-0 border-bottom border-2 text-uppercase fw-bold pb-2" data-tab="tab-desc" style="font-size:10px; letter-spacing:0.15em; color:var(--vino-on-surface); border-color:var(--vino-burgundy-light) !important;">DESCRIPCIÓN</button>
          </div>
          <div id="tab-desc" class="py-2">
            <p class="text-secondary" style="font-size:15px; line-height:1.6;">
              {{ producto_actual.descripcion }}
            </p>
          </div>
        </div>
      </div>
    </div>

    {% for section in sections %}
    {% if section.type == "product_grid" %}
    <section class="mt-5 pt-5 border-top border-secondary-subtle">
      <h2 class="text-uppercase fw-semibold mb-5 text-dark" style="font-size:13px; letter-spacing:.15em;">{{ section.title | upper }}</h2>
      <div class="row g-4">
        {% for prod in section.products %}
        <div class="col-6 col-lg-3">
          <a href="#" class="vino-card-link">
            <div class="vino-card h-100 d-flex flex-column">
              <div class="vino-card-img" style="padding:24px;">
                <img src="{{ prod.image }}" alt="{{ prod.name }}"/>
              </div>
              <div class="d-flex flex-column flex-grow-1" style="padding:20px;">
                <span class="text-uppercase fw-semibold d-block mb-1" style="font-size:10px; color:var(--vino-secondary); letter-spacing:0.13em;">{{ prod.brand }}</span>
                <h4 class="text-dark" style="font-size:16px; margin-bottom:0;">{{ prod.name }}</h4>
                <div class="mt-auto" style="padding-top:16px;">
                  <span class="text-dark" style="font-size:18px; font-weight:600; letter-spacing:0.02em;">₡{{ prod.price_crc }}</span>
                </div>
              </div>
            </div>
          </a>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}
    {% endfor %}

  </div>
</main>

<footer class="vino-footer">
  <div class="row g-4" style="max-width:1280px;margin:0 auto;">
    <div class="col-12 col-md-4">
      <span class="font-display fw-bold d-block mb-3 fs-5">{{ store_name | upper }}</span>
      <p class="text-secondary" style="font-size:13px; line-height:1.7;">{{ footer.slogan }}</p>
    </div>
    <div class="col-6 col-md-2">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">PRODUCTOS</span>
      {% for link in footer.quick_links %}
      <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
      {% endfor %}
    </div>
    <div class="col-6 col-md-3">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">TIENDA</span>
      {% for link in footer.store_links %}
      <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
      {% endfor %}
    </div>
    <div class="col-6 col-md-2">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">LEGAL</span>
      <p class="text-uppercase fw-semibold text-secondary mb-0" style="font-size:10px; letter-spacing:0.13em;">{{ footer.legal_text }}</p>
      <p class="text-secondary mt-4 mb-0 opacity-75" style="font-size:13px; letter-spacing:0.5px;">{{ footer.developed_by }}</p>
      <div class="d-flex gap-3 mt-3">
        <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">share</span></a>
        <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">public</span></a>
      </div>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="js/vinolillo.js"></script>
</body>
</html>