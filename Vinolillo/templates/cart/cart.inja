<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ store_name }} — Carrito de Compras</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="css/vinolillo.css"/>
</head>
<body>

<header class="vino-nav" id="mainNav">
  <div class="d-flex align-items-center gap-5 flex-grow-1">
    <a href="index.html" class="brand">{{ store_name | upper }}</a>
    <nav class="vino-nav-links">
      <a href="VinolilloCatalogPage.html">VINOS</a>
      <a href="VinolilloCatalogPage.html">DESTILADOS</a>
      <a href="VinolilloCatalogPage.html">CERVEZAS</a>
      <a href="VinolilloCatalogPage.html">LICORES</a>
      <a href="VinolilloCatalogPage.html">PROMOCIONES</a>
    </nav>
  </div>
  <div class="d-flex align-items-center gap-3 ms-auto">
    <button class="btn btn-link text-dark p-1" aria-label="Buscar"><span class="material-symbols-outlined">search</span></button>
    <button class="btn btn-link text-dark p-1" aria-label="Mi cuenta"><span class="material-symbols-outlined">settings</span></button>
    <a href="CartPage.html" class="text-dark p-1" style="position:relative; text-decoration:none;">
      <span class="material-symbols-outlined">shopping_cart</span>
      <span class="vino-cart-badge">{{ carrito.items | length }}</span>
    </a>
  </div>
</header>

<main class="page-content" style="padding-bottom:80px;">
  <div class="container-fluid" style="max-width:1280px; margin:0 auto; padding:40px var(--margin-desk);">

    <nav class="d-flex align-items-center py-3 text-uppercase fw-semibold mb-5" style="font-size:11px; letter-spacing:0.1em; color:var(--vino-muted); gap:4px;">
      <a href="index.html" class="text-decoration-none" style="color:var(--vino-secondary);">Inicio</a>
      <span class="material-symbols-outlined" style="font-size:14px; color:var(--vino-border);">chevron_right</span>
      <span style="color:var(--vino-on-surface);">Carrito de Compras</span>
    </nav>

    <h1 class="display-3 mb-5 text-uppercase fw-bold text-dark">Tu Selección</h1>

    <div class="row g-5">
      <div class="col-12 col-lg-8">
        <table class="w-100" style="border-collapse: collapse;">
          <thead>
            <tr class="border-bottom text-uppercase fw-bold" style="font-size:10px; letter-spacing:0.15em; color:var(--vino-muted);">
              <th class="pb-3">PRODUCTO</th>
              <th class="pb-3 text-end">PRECIO</th>
              <th class="pb-3 text-center">CANTIDAD</th>
              <th class="pb-3 text-end">SUBTOTAL</th>
            </tr>
          </thead>
          <tbody>
            {% for item in carrito.items %}
            <tr class="border-bottom border-secondary-subtle">
              <td class="py-4">
                <div class="d-flex align-items-center gap-4">
                  <img class="cart-item-img" src="{{ item.imagen }}" alt="{{ item.nombre }}"/>
                  <div>
                    <div class="font-display fw-semibold fs-5 text-dark mb-1">{{ item.nombre }}</div>
                    <div class="text-secondary" style="font-size:12px;">{{ item.detalle }}</div>
                  </div>
                </div>
              </td>
              <td class="py-4 text-end"><span class="fs-5 fw-semibold text-dark">₡{{ item.precio_crc }}</span></td>
              <td class="py-4 text-center">
                <div class="qty-stepper d-inline-flex">
                  <button class="px-2">−</button>
                  <span class="d-flex align-items-center justify-content-center border-start border-end fw-semibold" style="min-width:40px; font-size:14px;">{{ item.cantidad }}</span>
                  <button class="px-2">+</button>
                </div>
              </td>
              <td class="py-4 text-end"><span class="fs-5 fw-semibold text-dark">₡{{ item.subtotal_crc }}</span></td>
            </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="mt-4">
          <a href="VinolilloCatalogPage.html" class="btn-vino btn-vino-outline" style="text-decoration:none;">
            <span class="material-symbols-outlined fs-6">arrow_back</span>
            CONTINUAR COMPRANDO
          </a>
        </div>
      </div>

      <div class="col-12 col-lg-4">
        <div class="bg-white border p-4">
          <h3 class="text-uppercase fw-bold mb-4" style="font-size:11px; letter-spacing:0.15em;">RESUMEN DEL PEDIDO</h3>
          <div class="d-flex justify-content-between py-2 border-bottom border-secondary-subtle text-secondary" style="font-size:13px;">
            <span>Subtotal</span>
            <span class="text-dark fw-medium">₡{{ carrito.resumen.subtotal_crc }}</span>
          </div>
          <div class="d-flex justify-content-between py-2 border-bottom border-secondary-subtle text-secondary" style="font-size:13px;">
            <span>Envío</span>
            <span class="text-dark fw-medium">₡{{ carrito.resumen.envio_crc }}</span>
          </div>
          <div class="d-flex justify-content-between py-2 border-bottom border-secondary-subtle text-secondary" style="font-size:13px;">
            <span>IVA (13%)</span>
            <span class="text-dark fw-medium">₡{{ carrito.resumen.iva_crc }}</span>
          </div>
          <div class="d-flex flex-column gap-1 pt-3 mt-2 border-top">
            <div class="d-flex justify-content-between align-items-baseline">
              <span class="text-uppercase fw-semibold" style="font-size:11px; letter-spacing:0.13em;">TOTAL</span>
              <span class="text-burgundy-light fw-bold display-5">₡{{ carrito.resumen.total_crc }}</span>
            </div>
            <div class="text-end text-uppercase fw-semibold text-muted" style="font-size:10px; letter-spacing:0.1em;">CRC</div>
          </div>

          <a href="CheckoutPage.html" class="btn-vino btn-vino-burgundy w-100 mt-4 text-decoration-none">
            PROCEDER AL PAGO
          </a>
          <div class="d-flex align-items-center justify-content-center gap-2 mt-3 text-uppercase fw-bold text-muted" style="font-size:10px; letter-spacing:0.12em;">
            <span class="material-symbols-outlined" style="font-size:14px;">lock</span>
            PAGO SEGURO &amp; ENCRIPTADO
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 mt-4 border bg-light">
          <span class="material-symbols-outlined fs-5 text-burgundy-light flex-shrink-0">local_shipping</span>
          <p class="mb-0 text-secondary" style="font-size:13px;">
            Disfruta de <a href="VinolilloCatalogPage.html" class="text-burgundy-light text-decoration-none fw-medium">envío gratuito</a> en pedidos superiores a ₡{{ carrito.envio_gratis_desde_crc }}.
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

<footer class="vino-footer">
  <div class="row g-4" style="max-width:1280px;margin:0 auto;">
    <div class="col-12 col-md-4">
      <span class="font-display fw-bold d-block mb-3 fs-5">{{ store_name | upper }}</span>
      <p class="text-secondary" style="font-size:13px; line-height:1.7;">{{ footer.slogan }}</p>
    </div>
    <div class="col-6 col-md-2">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">PRODUCTOS</span>
      {% for link in footer.quick_links %}
      <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
      {% endfor %}
    </div>
    <div class="col-6 col-md-3">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">TIENDA</span>
      {% for link in footer.store_links %}
      <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
      {% endfor %}
    </div>
    <div class="col-6 col-md-2">
      <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">LEGAL</span>
      <p class="text-uppercase fw-semibold text-secondary mb-0" style="font-size:10px; letter-spacing:0.13em;">{{ footer.legal_text }}</p>
      <p class="text-secondary mt-4 mb-0 opacity-75" style="font-size:13px; letter-spacing:0.5px;">{{ footer.developed_by }}</p>
      <div class="d-flex gap-3 mt-3">
        <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">share</span></a>
        <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">public</span></a>
      </div>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="js/vinolillo.js"></script>
</body>
</html>