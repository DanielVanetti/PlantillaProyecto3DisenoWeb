<!DOCTYPE html>
<html lang="es" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ store_name }} — Inicio</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/assets/vinolillo.css" />
</head>

<body>

  <header class="vino-nav" id="mainNav">
    <div class="d-flex align-items-center gap-5 flex-grow-1">
      <a href="../home/index.html" class="brand">{{ store_name | upper }}</a>
      <nav class="vino-nav-links">
        <a href="../catalog/catalog.html">VINOS</a>
        <a href="../catalog/catalog.html">DESTILADOS</a>
        <a href="../catalog/catalog.html">CERVEZAS</a>
        <a href="../catalog/catalog.html">LICORES</a>
        <a href="../catalog/catalog.html">PROMOCIONES</a>
      </nav>
    </div>
    <div class="d-flex align-items-center gap-3 ms-auto">
      <a href="../catalog/catalog.html" class="text-dark p-1" style="position:relative; text-decoration:none;">
        <span class="material-symbols-outlined">search</span>
      </a>
      <button class="btn btn-link text-dark p-1" aria-label="Mi cuenta"><span class="material-symbols-outlined">settings</span></button>
      <a href="../cart/cart.html" class="text-dark p-1" style="position:relative; text-decoration:none;">
        <span class="material-symbols-outlined">shopping_cart</span>
        <span class="vino-cart-badge">2</span>
      </a>
    </div>
  </header>

  <main class="page-content">

    <div class="bg-white border-bottom px-4 px-md-5 overflow-hidden">
      <nav class="d-flex align-items-center py-3 text-uppercase fw-semibold" style="font-size:11px; letter-spacing:0.1em; color:var(--vino-muted); gap:4px;">
        <a href="#" class="text-decoration-none" style="color:var(--vino-secondary);">Inicio</a>
        <span class="material-symbols-outlined" style="font-size:14px; color:var(--vino-border);">chevron_right</span>
        <span style="color:var(--vino-on-surface);">Portada</span>
      </nav>
    </div>

    <section style="position:relative;min-height:640px;background:#0A0A0A;overflow:hidden;display:flex;align-items:center;">
      <img class="vino-hero-img" src="{{ hero.image_url }}" alt="Premium Wine" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;opacity:0.75;" />
      <div style="position:absolute;inset:0;background:linear-gradient(to right, rgba(10,10,10,0.9) 35%, transparent 75%);"></div>
      <div class="vino-hero-content fade-up" style="position:relative;z-index:2;padding:80px var(--margin-desk);max-width:540px;">
        <span class="font-label-caps" style="color:var(--vino-burgundy-light);letter-spacing:.3em;">
          {{ hero.tag }}</span>
        <h1 class="font-display-xl text-white mt-3 mb-4">{{ hero.headline }}</h1>
        <p class="font-body-lg mb-5" style="color:rgba(200,200,200,0.85);max-width:440px;">
          {{ hero.subheadline }}
        </p>
        <a href="{{ hero.cta.href }}" class="btn-vino-burgundy"
          style="font-size:12px;letter-spacing:.15em;padding:16px 40px;display:inline-flex;align-items:center;gap:8px;text-decoration:none;">
          {{ hero.cta.text }}
        </a>
      </div>
    </section>

    {% for section in sections %}
    {% if section.type == "product_grid" %}
    <section class="container-fluid" style="padding:96px var(--margin-desk); max-width:1280px; margin:0 auto;">
      <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
          <span class="text-uppercase fw-semibold text-burgundy-light d-block mb-2" style="font-size:11px; letter-spacing:0.2em;font-family: var(--font-body);font-size: 11px;color: var(--vino-burgundy-light);">{{ section.subtitle }}</span>
          <h2 class="fs-2 mb-0">{{ section.title }}</h2>
        </div>
        <a href="{{ section.view_all.href }}" class="text-uppercase fw-semibold text-decoration-none border-bottom pb-1" style="font-size:11px; letter-spacing:0.13em; color:var(--vino-on-surface); border-color:var(--vino-on-surface) !important;">{{ section.view_all.text }}</a>
      </div>

      <div class="row g-4">
        {% for prod in section.products %}
        <div class="col-12 col-sm-6 col-lg-3">
          <a href="{{ prod.href }}" class="vino-card-link">
            <div class="vino-card h-100 d-flex flex-column">
              <div class="vino-card-img{% if prod.badge_style == "ultra" %} {% endif %}">
                <img src="{{ prod.image }}" alt="{{ prod.name }}"{% if prod.badge_style == "burgundy" %} {% endif %}/>
                {% if prod.badge %}
                <span class="vino-card-badge {% if prod.badge_style == "burgundy" %}bg-burgundy{% else %}{% endif %}"{% if prod.badge_style == "ultra" %} style="background-color: var(--vino-ultra);"{% endif %}>{{ prod.badge }}</span>
                {% endif %}
              </div>
              <div class="d-flex flex-column flex-grow-1" style="padding: 20px;">
                <span class="text-uppercase fw-semibold d-block mb-1" style="font-size:10px; color:var(--vino-secondary); letter-spacing:0.13em;">{{ prod.origin }}</span>
                <h3 class="text-dark" style="font-size:16px; margin-bottom:0; transition:color 0.2s;">{{ prod.name }}</h3>
                <div class="d-flex justify-content-between align-items-center mt-auto" style="padding-top:16px;">
                  <span class="text-dark" style="font-size:18px; font-weight:600; letter-spacing:0.02em;">₡{{ prod.price_crc }}</span>
                  <button class="btn-vino-icon border-0" data-add-cart aria-label="Agregar al carrito" onclick="event.stopPropagation();">
                    <span class="material-symbols-outlined" style="font-size:20px;">add_shopping_cart</span>
                  </button>
                </div>
              </div>
            </div>
          </a>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}
    {% endfor %}

    <div class="bg-white border-top border-bottom" style="border-color:var(--vino-border) !important; padding:80px var(--margin-desk); text-align:center;">
      <div style="max-width:480px; margin:0 auto;">
        <span class="material-symbols-outlined mb-3" style="font-size:40px; color:#9c404e;">mail</span>
        <h2 class="mb-3" style="font-family:var(--font-display); font-size:clamp(24px, 3vw, 32px); font-weight:600;">{{ newsletter.title }}</h2>
        <p class="mb-0" style="color:var(--vino-secondary); font-size:15px; line-height:1.6;">
          {{ newsletter.text }}
        </p>
        <div class="d-flex flex-column flex-sm-row mt-4 mx-auto gap-0">
          <input class="flex-grow-1 bg-transparent border-0 border-bottom px-2 py-2 text-uppercase fw-semibold" style="font-size:11px; letter-spacing:0.1em; color:var(--vino-on-surface); outline:none; border-color:var(--vino-on-surface) !important;" type="email" placeholder="{{ newsletter.placeholder }}" />
          <button class="btn-vino btn-vino-primary border-0 mt-3 mt-sm-0">{{ newsletter.cta_text }}</button>
        </div>
      </div>
    </div>

  </main>

  <footer class="vino-footer">
    <div class="row g-4" style="max-width:1280px;margin:0 auto;">
      <div class="col-12 col-md-4">
        <span class="font-display fw-bold d-block mb-3 fs-5">{{ store_name | upper }}</span>
        <p class="text-secondary" style="font-size:13px; line-height:1.7;">{{ footer.slogan }}</p>
      </div>
      <div class="col-6 col-md-2">
        <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">PRODUCTOS</span>
        {% for link in footer.quick_links %}
        <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
        {% endfor %}
      </div>
      <div class="col-6 col-md-3">
        <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">TIENDA</span>
        {% for link in footer.store_links %}
        <a href="{{ link.href }}" class="d-block mb-2" style="font-size:13px;">{{ link.name }}</a>
        {% endfor %}
      </div>
      <div class="col-6 col-md-2">
        <span class="text-uppercase fw-bold d-block mb-3" style="font-size:10px; letter-spacing:0.18em;">LEGAL</span>
        <p class="text-uppercase fw-semibold text-secondary mb-0" style="font-size:10px; letter-spacing:0.13em;">{{ footer.legal_text }}</p>
        <p class="text-secondary mt-4 mb-0 opacity-75" style="font-size:13px; letter-spacing:0.5px;">{{ footer.developed_by }}</p>
        <div class="d-flex gap-3 mt-3">
          <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">share</span></a>
          <a href="#" style="color:var(--vino-secondary);"><span class="material-symbols-outlined">public</span></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="js/vinolillo.js"></script>
</body>

</html>